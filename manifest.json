{
  "manifest_version": 3,
  "name": "Browser Automation Extension",
  "version": "1.1",
  "description": "Record, save, import, export, and replay browser automations",
  "icons": {
    "16": "icon/browser-automation-logo.png",
    "32": "icon/browser-automation-logo.png",
    "48": "icon/browser-automation-logo.png",
    "128": "icon/browser-automation-logo.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs", "sidePanel"],
  "action": {
    "default_title": "Browser Automation Extension",
    "default_icon": {
      "16": "icon/browser-automation-logo.png",
      "32": "icon/browser-automation-logo.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
